{
    "$schema": "https://apify.com/schemas/v1/dataset.ide.json",
    "actorSpecification": 1,
    "fields": {
        "title": "Pages",
        "type": "object",
        "properties": {
            "title": {
                "type": "string",
                "title": "Title"
            },
            "url": {
                "type": "string",
                "format": "uri",
                "title": "URL"
            }
        },
        "required": [
            "title",
            "url"
        ]
    },
    "views": {
        "overview": {
            "title": "Overview",
            "transformation": {
                "fields": [
                    "title",
                    "url"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "title": {
                        "label": "Title",
                        "format": "text"
                    },
                    "url": {
                        "label": "URL",
                        "format": "link"
                    }
                }
            }
        }
    }
}
