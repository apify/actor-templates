{
    "name": "playwright-test",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "scripts": {
        "start": "npm run start:dev",
        "start:dev": "tsx src/main.ts",
        "start:prod": "node dist/main.js",
        "codegen": "tsx src/runCodegen.ts",
        "build": "tsc",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "echo \"Error: no test specified\" && exit 1",
        "// TODO": "revert postinstall to 'npx crawlee install-playwright-browsers' once https://github.com/patorjk/figlet.js/issues/167 is fixed/released",
        "postinstall": "node -e \"process.env.CRAWLEE_SKIP_BROWSER_INSTALL || require('node:child_process').execSync('npx playwright install', {stdio:'inherit'})\""
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@playwright/test": "1.60.0",
        "@types/uuid": "^11.0.0",
        "apify": "^3.7.0",
        "uuid": "^14.0.0",
        "@apify/eslint-config": "^2.0.0",
        "@apify/tsconfig": "^0.1.1",
        "@types/node": "^24.0.0",
        "eslint": "^9.29.0",
        "eslint-config-prettier": "^10.1.5",
        "globals": "^17.0.0",
        "prettier": "^3.5.3",
        "tsx": "^4.20.3",
        "typescript": "^6.0.0",
        "typescript-eslint": "^8.58.0"
    }
}
